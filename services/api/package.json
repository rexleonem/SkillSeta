{
  "name": "@skillseta/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --dts",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema ../../infra/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../../infra/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema ../../infra/prisma/schema.prisma"
  },
  "dependencies": {
    "@skillseta/config": "workspace:*",
    "@skillseta/types": "workspace:*",
    "@skillseta/utils": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "@prisma/client": "^6.12.0",
    "pino": "^9.8.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.0.0",
    "rate-limiter-flexible": "^5.0.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "prisma": "^6.12.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.4"
  }
}
